# =============================================================================
# SEO Office — local environment configuration
# =============================================================================
# Copy this file to `.env.local` and fill in your keys.
# `.env.local` is gitignored and stays on your machine — we never see it.
# Restart `pnpm dev` after editing.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — pick ONE LLM provider
# -----------------------------------------------------------------------------
# SEO Office can drive its specialists through any of these. If unset, it
# auto-picks the first installed + authenticated provider, preferring
# subscription-backed CLIs (no per-token bill) over an API key:
#
#   claude-cli      uses `claude` CLI + your Claude Pro/Max subscription
#   codex-cli       uses `codex`  CLI + ChatGPT login or OpenAI API-key login
#   gemini-cli      uses `gemini` CLI + your Google AI Pro subscription
#   anthropic-api   uses ANTHROPIC_API_KEY (pay per token)
#
# To force a specific provider, set this:
# SEO_OFFICE_LLM_PROVIDER=claude-cli

# If you choose `anthropic-api`, set the key here. Get one at:
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional Anthropic API endpoint override (proxy, AI Gateway, etc.)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Override the binary path for any CLI provider (defaults: just the name on PATH)
# SEO_OFFICE_CLAUDE_BIN=/usr/local/bin/claude
# SEO_OFFICE_CODEX_BIN=/usr/local/bin/codex
# SEO_OFFICE_GEMINI_BIN=/usr/local/bin/gemini
# SEO_OFFICE_GCLOUD_BIN=/usr/local/bin/gcloud

# -----------------------------------------------------------------------------
# Bring-your-own OAuth client for `gcloud auth application-default login`
# -----------------------------------------------------------------------------
# Set this if Google's consent screen blocks the default gcloud OAuth client
# ("This app is blocked"). Create a Desktop-type OAuth client in your own GCP
# project at https://console.cloud.google.com/apis/credentials, download the
# JSON, and upload it in /setup or point to it here. The Setup page explains
# the full flow and stores only the local file path in `.env.local`.
# SEO_OFFICE_GCLOUD_CLIENT_ID_FILE=/home/you/.config/seo-office/gcp-oauth-client.json

# -----------------------------------------------------------------------------
# RECOMMENDED — DataForSEO (SERP, keywords, competitors, backlinks)
# -----------------------------------------------------------------------------
# Sign up at https://dataforseo.com/ — pay-per-use, no monthly minimum
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# -----------------------------------------------------------------------------
# RECOMMENDED — Google API key (PageSpeed Insights + CrUX field data)
# -----------------------------------------------------------------------------
# Get an API key at https://console.cloud.google.com/apis/credentials
GOOGLE_API_KEY=

# -----------------------------------------------------------------------------
# RECOMMENDED — Google Cloud CLI (Search Console + GA4 via OAuth)
# -----------------------------------------------------------------------------
# Install gcloud (https://cloud.google.com/sdk/docs/install), then on first run
# open /setup and click "Sign in with Google Cloud" — that launches
#   gcloud auth application-default login --scopes=webmasters.readonly,...
# which writes credentials to ~/.config/gcloud/. No secret lives in this file.

# -----------------------------------------------------------------------------
# OPTIONAL — Google AI Studio / Gemini (image generation specialist only)
# -----------------------------------------------------------------------------
# Get a key at https://aistudio.google.com/apikey
# GOOGLE_AI_API_KEY=

# -----------------------------------------------------------------------------
# OPTIONAL — Bing Webmaster Tools (additional backlink data)
# -----------------------------------------------------------------------------
# Sign up at https://www.bing.com/webmasters/about
# BING_WEBMASTER_API_KEY=

# -----------------------------------------------------------------------------
# OPTIONAL — Firecrawl (full-site crawling for large audits)
# -----------------------------------------------------------------------------
# Sign up at https://firecrawl.dev/
# FIRECRAWL_API_KEY=

# -----------------------------------------------------------------------------
# Local paths (defaults are sensible — change only if you need to)
# -----------------------------------------------------------------------------
# Where the brain lives on disk
# SEO_OFFICE_DATA_DIR=./.seo-office

# Dev server port
# PORT=3000
